# ============================================================
# ACI GitOps Pipeline — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.
# ============================================================

# Cisco APIC credentials
APIC_HOST=sandboxapicdc.cisco.com
APIC_USERNAME=admin
APIC_PASSWORD=your-apic-password

# ServiceNow credentials
SNOW_INSTANCE=https://dev12345.service-now.com
SNOW_USERNAME=admin
SNOW_PASSWORD=your-snow-password
SNOW_ASSIGNMENT_GROUP=Network
